<UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/Hyphlow/EditorResources/Stylesheets/variableRow.uss?fileID=7433441132597879392&amp;guid=dc36f721c9349184d99e907b905f9005&amp;type=3#variableRow" />
    <engine:VisualElement name="VarRowRoot" style="flex-grow: 1; flex-direction: row;">
        <engine:Label text="Type Label" name="TypeLabel" view-data-key="TypeLabel" class="varRowTypeLabel" />
        <engine:TextField name="KeyInput" view-data-key="KeyInput" hide-placeholder-on-focus="true" binding-path="key" class="varRowInputField keyInput" />
        <engine:VisualElement name="ValueFieldHolder" view-data-key="ValueFieldHolder" style="flex-grow: 1;" />
        <engine:EnumField value="Private" type="AtMycelia.Hyphlow.VariableScope, AtMycelia.Hyphlow.Core" name="Scope" data-source-type="AtMycelia.Hyphlow.VariableScope, AtMycelia.Hyphlow.Core" view-data-key="Scope" binding-path="scope" class="scopeRoot" />
        <engine:Button text="-" name="RemoveButton" view-data-key="RemoveButton" class="removeButton" />
    </engine:VisualElement>
</UXML>
