<UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <Style src="project://database/Assets/Hyphlow/Resources/Editor/Stylesheets/VarRows/variableRowStyle.uss?fileID=7433441132597879392&amp;guid=dc36f721c9349184d99e907b905f9005&amp;type=3#variableRowStyle" />
    <Style src="project://database/Assets/Hyphlow/Resources/Editor/Stylesheets/VarRows/colliderThreeDStyle.uss?fileID=7433441132597879392&amp;guid=8fa47d68ce2b2234daa4c2658944c3e3&amp;type=3#colliderThreeDStyle" />
    <Style src="project://database/Assets/Hyphlow/Resources/Editor/Stylesheets/VarRows/generalThreeDStyle.uss?fileID=7433441132597879392&amp;guid=326e743019ac6d846844d16bf9ae97cd&amp;type=3#generalThreeDStyle" />
    <engine:VisualElement name="VarRowRoot" style="flex-grow: 1; flex-direction: row;">
        <engine:Label text="Collider3D" name="TypeLabel" class="varRowTypeLabel" style="text-shadow: 5px 5px 0 rgb(0, 0, 0);" />
        <engine:TextField name="KeyInput" hide-placeholder-on-focus="true" binding-path="_key" class="varRowInputField keyInput" />
        <engine:VisualElement name="ValueFieldHolder" view-data-key="ValueField">
            <editor:ObjectField data-source-type="UnityEngine.Collider, UnityEngine.PhysicsModule" name="ValueField" binding-path="_value" focusable="false" type="UnityEngine.Transform, UnityEngine.CoreModule" class="objField" />
        </engine:VisualElement>
        <engine:EnumField value="Private" type="AtMycelia.Hyphlow.VariableScope, AtMycelia.Hyphlow.Core" name="Scope" data-source-type="AtMycelia.Hyphlow.VariableScope, AtMycelia.Hyphlow.Core" binding-path="_scope" class="scopeRoot" />
        <engine:Button text="-" name="RemoveButton" class="removeButton" />
    </engine:VisualElement>
</UXML>
