#VarRowRoot 
{
    flex-direction: row;
    height: 30px;
    margin-bottom: 3px;
    border-radius: 2px;
}

.removeButton 
{
    width: 30px;
    border-radius: 2px;
    padding: 0px;
    margin: 0px 0px 0px 2px;
}

.varRowTypeLabel
{
    -unity-font-definition: resource('Runtime/Fonts/Amaranth/Amaranth-Regular');
    color: rgb(229, 229, 229);
    -unity-text-align: middle-left;
    width: 75px;
    padding: 0 0 0 5px;
    margin: 0px;
    font-size: 14px;
}

.keyInput
{
    background-color: rgb(26, 26, 26);
    color: rgb(230, 230, 230);
    border-radius: 2px;
    padding: 0 2px 0 2px;
    width: 130px;
    margin: 0 2px 0 1px;
}

.keyInput > #unity-text-input
{
    -unity-font-definition: resource('Runtime/Fonts/Amaranth/Amaranth-Regular');
    background-color: rgb(26, 26, 26);
    color: rgb(230, 230, 230);
    border-radius: 2px;
    padding: 2px;
    width: 150px;
    margin: 0;
    font-size: 14px;
}

#ValueFieldHolder
{
    flex-grow: 0;
    width: 120px;
    padding: 0;
    -unity-text-align: middle-left;
    border-radius: 2px;
    border-color: white;
    font-size: 14px;
    margin: 0px 3px 0px 0px;

}

.scopeRoot 
{
    -unity-font-definition: resource('Runtime/Fonts/Amaranth/Amaranth-Regular');
    width: 75px;
    display: flex;
    flex-direction: row;
    height: 100%;
    padding: 0px;
    margin: 0px 2px 0px 0px;
    font-size: 14px;
}

.scopeRoot > VisualElement 
{
    height: 100%;
    padding: 0px;
    margin: 0;
    border-radius: 2px;
}

.scopeRoot > VisualElement > VisualElement 
{
    width: 20%;
    height: 50%;
    flex-shrink: 1;
}

.scopeRoot > VisualElement > TextElement 
{
    height: 100%;
    flex-shrink: 0;
    margin: 0;
    padding-left: 3px;
    font-size: 14px;
}

#KeyInput > #unity-text-input
{
    font-size: 14px;
}